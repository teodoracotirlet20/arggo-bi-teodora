	partition ClusterMappingTable = calculated
		mode: import
		source = ```
				VAR __DS0Core = 
					SUMMARIZECOLUMNS(
						'Dim_Category'[Code],
						"SumDiscount_Amount", CALCULATE(SUM('Fact_ValueEntry'[Discount Amount])),
						"SumSales_Amount__Actual_", CALCULATE(SUM('Fact_ValueEntry'[Sales Amount (Actual)]))
					)
				
				VAR __DataTransformT0 = 
					KMeansClustering(
						SELECTCOLUMNS(
							__DS0Core,
							"Code", 'Dim_Category'[Code],
							"SumDiscount_Amount", [SumDiscount_Amount],
							"SumSales_Amount__Actual_", [SumSales_Amount__Actual_]
						),
						{("[Code]", "Item"),
							("[SumDiscount_Amount]", "Attribute"),
							("[SumSales_Amount__Actual_]", "Attribute")},
						{("[Code]", BLANK()),
							("ClusterId", "ClusterId")},
						3
					)
				
				RETURN __DataTransformT0
				```
			retainDataTillForceCalculate

	annotation ClusterMappingTable = true

	annotation __PBI_SemanticLinks = [{"LinkTarget":{"TableName":"Dim_Category","TableItemName":"Code (clusters)","ObjectType":4},"LinkType":"UsedInGroup"}]

