	column 'Code (groups)' =
			SWITCH(
				TRUE,
				ISBLANK('Dim_Category'[Code]),
				"(Blank)",
				'Dim_Category'[Code] IN {"MISC",
					"CHAIR"},
				"CHAIR & MISC",
				"Other"
			)
